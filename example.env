# Токен бота от BotFather
BOT_TOKEN=

# Telegram ID администратора
ADMIN_ID=

# Название сервиса в приветствии пользователя: "Привет! Это поддержка <SERVICE_NAME>."
SERVICE_NAME=Example

# Префикс тикетов. По умолчанию бот использует AA и создаёт ID вида AA-XXXXXX.
TICKET_PREFIX=AA

# Дебаунс авто-подтверждения и уведомления администратора, в секундах
ACK_DELAY=30

# Пути к JSON-файлам и папке с историями сообщений
USERS_PATH=data/users.json
TICKETS_PATH=data/tickets.json
MESSAGES_PATH=data/messages
